## Database Changes Required for Account Settings

```sql
-- Users (personal profile)
ALTER TABLE users ADD COLUMN timezone TEXT DEFAULT 'UTC';
ALTER TABLE users ADD COLUMN date_format TEXT DEFAULT 'MM/DD/YYYY';
ALTER TABLE users ADD COLUMN avatar_url TEXT;

-- Tenants (organization + CAN-SPAM fix)
ALTER TABLE tenants ADD COLUMN company_name TEXT;
ALTER TABLE tenants ADD COLUMN business_address TEXT;  -- fixes hardcoded "123 Main St"
ALTER TABLE tenants ADD COLUMN business_city TEXT;
ALTER TABLE tenants ADD COLUMN business_state TEXT;
ALTER TABLE tenants ADD COLUMN business_zip TEXT;
ALTER TABLE tenants ADD COLUMN business_country TEXT;
ALTER TABLE tenants ADD COLUMN industry TEXT;
ALTER TABLE tenants ADD COLUMN currency TEXT DEFAULT 'USD';
ALTER TABLE tenants ADD COLUMN utm_source TEXT;
ALTER TABLE tenants ADD COLUMN utm_medium TEXT;
ALTER TABLE tenants ADD COLUMN utm_campaign TEXT;
ALTER TABLE tenants ADD COLUMN unsubscribe_type TEXT DEFAULT 'one-click';
ALTER TABLE tenants ADD COLUMN require_double_optin BOOLEAN DEFAULT false;
ALTER TABLE tenants ADD COLUMN retention_months INTEGER DEFAULT 24;
ALTER TABLE tenants ADD COLUMN sending_domain TEXT;
ALTER TABLE tenants ADD COLUMN domain_verified BOOLEAN DEFAULT false;
ALTER TABLE tenants ADD COLUMN warmup_day INTEGER DEFAULT 0;

-- Contacts (preference center)
ALTER TABLE contacts ADD COLUMN email_frequency TEXT DEFAULT 'no_preference';
ALTER TABLE contacts ADD COLUMN paused_until TIMESTAMPTZ;
ALTER TABLE contacts ADD COLUMN subscribed_categories JSONB;

-- New tables
CREATE TABLE audit_logs (
  id UUID PRIMARY KEY, tenant_id UUID, user_id UUID, action TEXT,
  target TEXT, target_id TEXT, metadata JSONB, ip_address TEXT,
  user_agent TEXT, created_at TIMESTAMPTZ DEFAULT now()
);

CREATE TABLE api_keys (
  id UUID PRIMARY KEY, tenant_id UUID, name TEXT, key_hash TEXT,
  scopes JSONB, last_used_at TIMESTAMPTZ, created_at TIMESTAMPTZ,
  revoked_at TIMESTAMPTZ
);

CREATE TABLE webhooks (
  id UUID PRIMARY KEY, tenant_id UUID, url TEXT, events JSONB,
  secret TEXT, is_active BOOLEAN DEFAULT true, created_at TIMESTAMPTZ
);
```

